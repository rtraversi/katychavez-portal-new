{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:8888",
          "http://localhost:3000",
          "http://127.0.0.1:8888",
          "https://*.netlify.app",
          "https://*.workers.dev"
        ],
        "methods": ["GET", "PUT"],
        "headers": ["Content-Type", "Content-Length", "Content-Disposition"]
      },
      "maxAgeSeconds": 3600
    }
  ]
}
